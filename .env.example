# URL database Turso, contoh: libsql://nama-db-org.turso.io
TURSO_DATABASE_URL=

# Auth token dari `turso db tokens create nama-db`
TURSO_AUTH_TOKEN=

# String acak untuk enkripsi session NextAuth, generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=

# URL aplikasi setelah deploy, contoh: https://nama-app.vercel.app
NEXTAUTH_URL=
